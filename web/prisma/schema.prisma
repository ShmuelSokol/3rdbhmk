generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Book {
  id         String   @id @default(cuid())
  name       String
  filename   String
  totalPages Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  pages      Page[]

  @@map("bhmk_book")
}

model Page {
  id              String            @id @default(cuid())
  bookId          String
  book            Book              @relation(fields: [bookId], references: [id])
  pageNumber      Int
  imageUrl        String?
  imagePath       String?
  status          String            @default("pending")
  pipelineStatus  String            @default("pending") // pending | step1_ocr | step2_regions | step3_erased | step4_expanded | step5_fitted | step6_verified | locked
  lockedAt        DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  ocrResult       OCRResult?
  translation     Translation?
  layout          PageLayout?
  flags           Flag[]
  regions         ContentRegion[]
  erasedImage     ErasedImage?
  fittedPage      FittedPage?
  verificationOcr VerificationOcr?

  @@unique([bookId, pageNumber])
  @@map("bhmk_page")
}

model PageLayout {
  id        String   @id @default(cuid())
  pageId    String   @unique
  page      Page     @relation(fields: [pageId], references: [id])
  regions   Json     // Array of {type, x, y, width, height, label?}
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bhmk_page_layout")
}

model OCRResult {
  id        String        @id @default(cuid())
  pageId    String        @unique
  page      Page          @relation(fields: [pageId], references: [id])
  rawJson   Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  boxes     BoundingBox[]

  @@map("bhmk_ocr_result")
}

model BoundingBox {
  id              String    @id @default(cuid())
  ocrResultId     String
  ocrResult       OCRResult @relation(fields: [ocrResultId], references: [id], onDelete: Cascade)
  x               Float
  y               Float
  width           Float
  height          Float
  hebrewText      String
  editedText      String?
  englishText     String?
  confidence      Float?
  lineIndex       Int?
  wordIndex       Int?
  isImage         Boolean   @default(false)
  skipTranslation Boolean   @default(false)
  textPixelSize   Float?    // Estimated font size in pixels
  textPixelWidth  Float?    // Measured text width in pixels
  isBold          Boolean   @default(false)
  regionId        String?   // Link to ContentRegion after step 2
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("bhmk_bounding_box")
}

model Translation {
  id            String   @id @default(cuid())
  pageId        String   @unique
  page          Page     @relation(fields: [pageId], references: [id])
  hebrewInput   String   @db.Text
  englishOutput String   @db.Text
  status        String   @default("draft")
  reviewNotes   String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("bhmk_translation")
}

model Flag {
  id        String   @id @default(cuid())
  pageId    String
  page      Page     @relation(fields: [pageId], references: [id])
  x         Float
  y         Float
  width     Float
  height    Float
  type      String
  note      String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bhmk_flag")
}

model ContentRegion {
  id             String   @id @default(cuid())
  pageId         String
  page           Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  regionIndex    Int      // Order on page (top-to-bottom)
  regionType     String   @default("body") // body | header | footer | table | image
  // Original detected coordinates (% of image)
  origX          Float
  origY          Float
  origWidth      Float
  origHeight     Float
  // Expanded coordinates (% of image) — after step 4
  expandedX      Float?
  expandedY      Float?
  expandedWidth  Float?
  expandedHeight Float?
  // Manual override coordinates (% of image) — user adjustments
  manualX        Float?
  manualY        Float?
  manualWidth    Float?
  manualHeight   Float?
  // Text fitting results from step 5
  fittedFontSize Float?   // Final font size in px used for English
  fittedText     String?  @db.Text // The English text rendered in this region
  hebrewText     String?  @db.Text // Original Hebrew text from this region
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([pageId, regionIndex])
  @@map("bhmk_content_region")
}

model ErasedImage {
  id          String   @id @default(cuid())
  pageId      String   @unique
  page        Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  storagePath String   // Supabase storage path for erased PNG
  width       Int      // Image width in px
  height      Int      // Image height in px
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("bhmk_erased_image")
}

model FittedPage {
  id          String   @id @default(cuid())
  pageId      String   @unique
  page        Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  storagePath String   // Supabase storage path for fitted English PNG
  width       Int
  height      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("bhmk_fitted_page")
}

model VerificationOcr {
  id             String   @id @default(cuid())
  pageId         String   @unique
  page           Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  expectedWords  Json     // Array of expected English words
  foundWords     Json     // Array of words found by verification OCR
  missingWords   Json     // Array of words not found
  extraWords     Json     // Array of unexpected words found
  passRate       Float    // 0-1, percentage of expected words found
  passed         Boolean  @default(false) // true if passRate >= threshold
  ocrRawJson     Json?    // Full OCR response for debugging
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("bhmk_verification_ocr")
}
